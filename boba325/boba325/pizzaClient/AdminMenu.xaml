<Window x:Class="pizza.AdminMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizza"
        mc:Ignorable="d"
        Title="AdminMenu" Height="450" Width="800"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="43*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="images/smoke1.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <ContentControl Grid.Row="0"
                        Grid.ColumnSpan="3"
                        ContentTemplate="{StaticResource AdminHeaderTemplate}" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="#D9E1E8"
                BorderBrush="White"
                BorderThickness="1"
                Width="930"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1E6B8F">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="0.35*"/>
                        <ColumnDefinition Width="1.3*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="מוצר" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="קטגוריה" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="מחיר" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                </Grid>

                <DataGrid x:Name="ProductsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="False"
                          CanUserResizeRows="False"
                          IsReadOnly="False"
                          GridLinesVisibility="All"
                          RowBackground="#D9E1E8"
                          AlternatingRowBackground="#C7D0D8"
                          BorderThickness="0"
                          FontSize="16"
                          RowHeight="62"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowEditEnding="ProductsGrid_RowEditEnding"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2.2*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Width="1.7*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTemplateColumn Width="0.35*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Width="1.3*" ElementStyle="{StaticResource OrderCellStyleBold}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,18">
                    <Button Content="מחק"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="DeleteButton_Click"/>
                    <Button Content="הוסף"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="AddButton_Click"/>
                    <Button Content="נקה"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
