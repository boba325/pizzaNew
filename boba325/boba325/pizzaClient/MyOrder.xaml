<Window x:Class="pizza.MyOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizza"
        mc:Ignorable="d"
        Title="MyOrder" Height="450" Width="800"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="43*"/>
        </Grid.ColumnDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="images/smoke1.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="2.7*"/>
            <RowDefinition Height="5.3*"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" Grid.ColumnSpan="3"
                        ContentTemplate="{StaticResource UserHeaderTemplate}" />

        <StackPanel x:Name="OrderTableSection"
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,20">
            <Border Background="#D9E1E8"
                    BorderBrush="White"
                    BorderThickness="1"
                    Width="930"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#1E6B8F">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="1.7*"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.7*"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="מוצר" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="קטגוריה" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="קופון" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="כמות" Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text='מחיר' Foreground="White" FontSize="18" FontWeight="Bold" Padding="18,14" TextAlignment="Center"/>
                    </Grid>

                    <DataGrid x:Name="OrderItemsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              HeadersVisibility="None"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeColumns="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              RowBackground="#D9E1E8"
                              AlternatingRowBackground="#C7D0D8"
                              BorderThickness="0"
                              FontSize="16"
                              RowHeight="62"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="2.2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProductName}"
                                                       Style="{StaticResource OrderCellStyle}"/>
                                            <TextBlock Text="{Binding Details}"
                                                       Foreground="#2E2E2E"
                                                       FontSize="12"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Category}" Width="1.7*" ElementStyle="{StaticResource OrderCellStyle}"/>
                            <DataGridTextColumn Binding="{Binding UnitPriceDisplay}" Width="1.3*" ElementStyle="{StaticResource OrderCellStyle}"/>
                            <DataGridTemplateColumn Width="1.7*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <StackPanel x:Name="AmountPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="-" Width="32" Height="32" Margin="0,0,10,0" Click="DecreaseAmount_Click"/>
                                                <TextBlock Text="{Binding QuantityDisplay}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#111111"/>
                                                <Button Content="+" Width="32" Height="32" Margin="10,0,0,0" Click="IncreaseAmount_Click"/>
                                            </StackPanel>
                                            <TextBlock x:Name="SummaryAmountText" Text="" Visibility="Collapsed"/>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSummaryRow}" Value="True">
                                                <Setter TargetName="AmountPanel" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="SummaryAmountText" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding LineTotalDisplay}" Width="1.3*" ElementStyle="{StaticResource OrderCellStyleBold}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Button x:Name="OrderButton"
                    Content="הזמן"
                    Width="240"
                    Height="74"
                    FontSize="28"
                    Margin="0,18,0,0"
                    Click="OrderButton_Click"/>
        </StackPanel>

        <Grid x:Name="OrderStatusSection"
              Grid.Row="1"
              Grid.ColumnSpan="3"
              Visibility="Collapsed"
              Margin="40,20,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusTitleText"
                       Text="הזמנתך מתקדמת!"
                       Foreground="White"
                       FontSize="34"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,28"/>

            <Grid Grid.Row="1"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="images/Order/Order2.png"
                           Stretch="Uniform"
                           Width="220"
                           Height="160"/>
                    <TextBlock Text="הכנה"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="images/Order/Order3.png"
                           Stretch="Uniform"
                           Width="220"
                           Height="160"/>
                    <TextBlock Text="אריזה"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="images/Order/Order4.png"
                           Stretch="Uniform"
                           Width="220"
                           Height="160"/>
                    <TextBlock Text="משלוח"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Width="360"
                        Height="26"
                        CornerRadius="13"
                        Background="#D62839"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Width="360"
                        Height="26"
                        CornerRadius="13"
                        Background="#FFB000"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                <Border Grid.Row="1"
                        Grid.Column="2"
                        Width="360"
                        Height="26"
                        CornerRadius="13"
                        Background="#8BD11C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                <Polygon x:Name="Level2Triangle"
                         Grid.Row="2"
                         Grid.Column="0"
                         Points="0,46 60,46 30,0"
                         Fill="#D62839"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Visibility="Collapsed"/>
                <Polygon x:Name="Level3Triangle"
                         Grid.Row="2"
                         Grid.Column="1"
                         Points="0,46 60,46 30,0"
                         Fill="#FF7A1A"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Visibility="Collapsed"/>
                <Polygon x:Name="Level4Triangle"
                         Grid.Row="2"
                         Grid.Column="2"
                         Points="0,46 60,46 30,0"
                         Fill="#8BD11C"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Visibility="Collapsed"/>

                <TextBlock x:Name="StatusDescriptionText"
                           Grid.Row="3"
                           Grid.ColumnSpan="3"
                           Text="הזמנתך התקבלה וכרגע בטיפול!"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button x:Name="CancelOrderButton"
                        Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Content="בטל הזמנה"
                        Width="220"
                        Height="58"
                        FontSize="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="CancelOrderButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
