<Window x:Class="pizza.MenuPizza"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizza"
        mc:Ignorable="d"
        Title="תפריט פיצה" Height="450" Width="800"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="43*"/>
        </Grid.ColumnDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="images/rekaNew.png" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="2.7*"/>
            <RowDefinition Height="5.3*"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" Grid.ColumnSpan="3"
                        ContentTemplate="{StaticResource UserHeaderTemplate}" />

        <!-- Left side: two vertical columns of topping buttons -->
        <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
            <Grid Width="520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- First column of toppings -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Content="פפרוני" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                    <Button Content="אנשובי" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                    <Button Content="טונה" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                    <Button Content="זיתים" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                </StackPanel>

                <!-- Second column of toppings -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Content="בצל" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                    <Button Content="פלפל ירוק" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                    <Button Content="אננס" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                    <Button Content="קבנוס" Width="240" Height="80" Margin="6" Click="ToppingButton_Click" />
                </StackPanel>

                <Button x:Name="ClearToppingsButton"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Content="Clear Toppings"
                        Width="240"
                        Height="60"
                        Margin="6,24,6,0"
                        HorizontalAlignment="Center"
                        Click="ClearToppingsButton_Click"/>
            </Grid>
        </Grid>

        <!-- Right side: larger pizza image behind the existing slice canvas. -->
        <Grid Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
            <Grid Width="800" Height="800" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="19*"/>
                    <RowDefinition Height="61*"/>
                </Grid.RowDefinitions>
                <Image x:Name="PizzaImage"
                       Source="images/Menu/pizzaMenu.png"
                       Stretch="Uniform"
                       Width="800" Height="800"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" Grid.RowSpan="2"/>

                <Canvas x:Name="PizzaCanvas" Width="600" Height="600"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        SnapsToDevicePixels="True" Background="Transparent" Margin="100" Grid.RowSpan="2"/>
            </Grid>
        </Grid>

        <!-- Bottom center Add to Order button -->
        <Button x:Name="AddToOrderButton"
                Grid.Row="1"
                Grid.ColumnSpan="3"
                Content="הוסף להזמנה"
                Width="300"
                Height="70"
                FontSize="20"
                Margin="0,0,0,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Click="AddToOrderButton_Click"
                />
    </Grid>
</Window>
