<Window x:Class="pizza.AddOrderPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Order"
        Height="520"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">
    <Grid Margin="20">
        <Border BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="הוספת הזמנה"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,22"
                               TextAlignment="Center"/>

                    <TextBlock Text="UserID" Margin="0,4,0,6"/>
                    <TextBox x:Name="UserIdBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,12"/>

                    <TextBlock Text="כתובת" Margin="0,4,0,6"/>
                    <TextBox x:Name="AddressBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,12"/>

                    <TextBlock Text="תאריך" Margin="0,4,0,6"/>
                    <TextBox x:Name="DateBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,12"/>

                    <TextBlock Text="סטטוס הזמנה" Margin="0,4,0,6"/>
                    <TextBox x:Name="OrderLevelBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,12"/>

                    <CheckBox x:Name="IsApprovedCheckBox"
                              Content="האם אושר"
                              Margin="0,8,0,20"
                              FontSize="14"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="הוסף"
                                Width="120"
                                Background="#4CAF50"
                                Foreground="White"
                                Height="45"
                                Margin="8"
                                Click="Done_Click"/>
                        <Button Content="בטל"
                                Width="120"
                                Background="#f44336"
                                Foreground="White"
                                Height="45"
                                Margin="8"
                                Click="Cancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
