<Window x:Class="pizza.AdminOrders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizza"
        mc:Ignorable="d"
        Title="AdminOrders" Height="450" Width="800"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="43*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="images/smoke1.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <ContentControl Grid.Row="0"
                        Grid.ColumnSpan="3"
                        ContentTemplate="{StaticResource AdminHeaderTemplate}" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="#D9E1E8"
                BorderBrush="White"
                BorderThickness="1"
                Width="1200"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1E6B8F">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1.8*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="OrderID" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="UserID" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="כתובת" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="תאריך" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="האם אושר" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="סטטוס" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="מוצרים" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                </Grid>

                <DataGrid x:Name="OrdersGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="False"
                          CanUserResizeRows="False"
                          IsReadOnly="False"
                          GridLinesVisibility="All"
                          RowBackground="#D9E1E8"
                          AlternatingRowBackground="#C7D0D8"
                          BorderThickness="0"
                          FontSize="15"
                          RowHeight="58"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowEditEnding="OrdersGrid_RowEditEnding"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Id}" Width="0.9*" IsReadOnly="True" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding UserId}" Width="0.9*" IsReadOnly="True" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="2.1*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Date, UpdateSourceTrigger=PropertyChanged}" Width="1.8*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTemplateColumn Width="1.1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="120"
                                            Height="38"
                                            Click="ToggleApproval_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Content" Value="Approve"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                        <Setter Property="Content" Value="Cancel Order"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="1.1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Content="-"
                                                Width="28"
                                                Height="28"
                                                Margin="0,0,8,0"
                                                Click="DecreaseLevel_Click"/>
                                        <TextBlock Text="{Binding OrderLevel}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#111111"/>
                                        <Button Content="+"
                                                Width="28"
                                                Height="28"
                                                Margin="8,0,0,0"
                                                Click="IncreaseLevel_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="View Products"
                                            Width="130"
                                            Height="38"
                                            Click="ViewProducts_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,18">
                    <Button Content="מחק"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="DeleteButton_Click"/>
                    <Button Content="הוסף"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="AddButton_Click"/>
                    <Button Content="נקה"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
