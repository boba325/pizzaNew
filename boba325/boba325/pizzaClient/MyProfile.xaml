<Window x:Class="pizza.MyProfile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizza"
        mc:Ignorable="d"
        Title="MyProfile" Height="450" Width="800"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="43*"/>
        </Grid.ColumnDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="images/smoke1.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="2.7*"/>
            <RowDefinition Height="5.3*"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" Grid.ColumnSpan="3"
                        ContentTemplate="{StaticResource UserHeaderTemplate}" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                MaxWidth="720"
                Margin="40,20,40,40"
                Padding="28"
                Background="#CCFFFFFF"
                BorderBrush="White"
                BorderThickness="2"
                CornerRadius="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="פרופיל אישי (placeholder)"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#8B0000"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Name:" Margin="0,0,12,12" FontWeight="Bold"/>
                    <TextBlock x:Name="FullNameText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" Margin="0,0,12,12" FontWeight="Bold"/>
                    <TextBlock x:Name="EmailText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Phone:" Margin="0,0,12,12" FontWeight="Bold"/>
                    <TextBlock x:Name="PhoneText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Address:" Margin="0,0,12,12" FontWeight="Bold"/>
                    <TextBlock x:Name="AddressText" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Birthday:" Margin="0,0,12,0" FontWeight="Bold"/>
                    <TextBlock x:Name="BirthdayText" Grid.Row="5" Grid.Column="1"/>
                </Grid>

                <Button Content="Logout"
                        Width="180"
                        Height="48"
                        HorizontalAlignment="Center"
                        Click="Logout_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
