<Window x:Class="pizza.AdminUsers"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizza"
        mc:Ignorable="d"
        Title="AdminUsers" Height="450" Width="800"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="43*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="images/smoke1.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <ContentControl Grid.Row="0"
                        Grid.ColumnSpan="3"
                        ContentTemplate="{StaticResource AdminHeaderTemplate}" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="#D9E1E8"
                BorderBrush="White"
                BorderThickness="1"
                Width="1200"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1E6B8F">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1.8*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="שם פרטי" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="שם משפחה" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="אימייל" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="סיסמה" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="טלפון" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="כתובת" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="7" Text="תאריך לידה" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                    <TextBlock Grid.Column="8" Text="Admin" Foreground="White" FontSize="18" FontWeight="Bold" Padding="14,14" TextAlignment="Center"/>
                </Grid>

                <DataGrid x:Name="UsersGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="False"
                          CanUserResizeRows="False"
                          IsReadOnly="False"
                          GridLinesVisibility="All"
                          RowBackground="#D9E1E8"
                          AlternatingRowBackground="#C7D0D8"
                          BorderThickness="0"
                          FontSize="15"
                          RowHeight="58"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowEditEnding="UsersGrid_RowEditEnding"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Id}" Width="0.7*" IsReadOnly="True" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding FName, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding LName, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Width="1.7*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="1.8*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridTextColumn Binding="{Binding Bday, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" ElementStyle="{StaticResource OrderCellStyle}"/>
                        <DataGridCheckBoxColumn Binding="{Binding IsAdmin, UpdateSourceTrigger=PropertyChanged}" Width="0.9*">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                            <DataGridCheckBoxColumn.EditingElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.EditingElementStyle>
                        </DataGridCheckBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,18">
                    <Button Content="מחק"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="DeleteButton_Click"/>
                    <Button Content="הוסף"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="AddButton_Click"/>
                    <Button Content="נקה"
                            Width="150"
                            Height="54"
                            Margin="12,0"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
