<Window x:Class="pizza.SignupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="הרשמה" Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">
    <Grid Margin="20">
        <!-- Border around the scrollable area -->
        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="2" Background="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Background}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True"
                          Padding="0,0,12,0">
                <!-- Add a small inner margin so controls are not flush to the border/scrollbar -->
                <StackPanel VerticalAlignment="Top" Margin="8,6,8,6">
                    <TextBlock Text="הרשמה למערכת" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" TextAlignment="Center"/>
                    
                    <!-- First Name -->
                    <TextBlock Text="שם פרטי:" Margin="0,10,0,5"/>
                    <TextBox x:Name="FirstNameBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Last Name -->
                    <TextBlock Text="שם משפחה:" Margin="0,10,0,5"/>
                    <TextBox x:Name="LastNameBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Email -->
                    <TextBlock Text="אימייל:" Margin="0,10,0,5"/>
                    <TextBox x:Name="EmailBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Password -->
                    <TextBlock Text="סיסמה:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="PasswordBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Confirm Password -->
                    <TextBlock Text="אישור סיסמה:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Phone -->
                    <TextBlock Text="טלפון:" Margin="0,10,0,5"/>
                    <TextBox x:Name="PhoneBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Address -->
                    <TextBlock Text="כתובת:" Margin="0,10,0,5"/>
                    <TextBox x:Name="AddressBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Birthday -->
                    <TextBlock Text="תאריך לידה (YYYY-MM-DD):" Margin="0,10,0,5"/>
                    <TextBox x:Name="BirthdayBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,20"/>
                    
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="הרשמה" Width="120" Height="45" Margin="10" Click="Signup_Click" Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <Button Content="ביטול" Width="120" Height="45" Margin="10" Click="Cancel_Click" Background="#f44336" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>