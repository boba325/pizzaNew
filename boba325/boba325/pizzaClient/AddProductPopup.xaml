<Window x:Class="pizza.AddProductPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Product"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">
    <Grid Margin="20">
        <Border BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="הוספת מוצר"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,22"
                               TextAlignment="Center"/>

                    <TextBlock Text="שם המוצר" Margin="0,4,0,6"/>
                    <TextBox x:Name="NameBox"
                             Height="40"
                             Padding="10"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="קטגוריה" Margin="0,4,0,6"/>
                    <ComboBox x:Name="CategoryComboBox"
                              Height="40"
                              FontSize="14"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="מחיר" Margin="0,4,0,6"/>
                    <TextBox x:Name="PriceBox"
                             Height="40"
                             Padding="10"
                             FontSize="14"
                             Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="הוסף"
                                Width="120"
                                Background="#4CAF50"
                                Foreground="White"
                                Height="45"
                                Margin="8"
                                Click="Done_Click"/>
                        <Button Content="ביטול"
                                Width="120"
                                Background="#f44336"
                                Foreground="White"
                                Height="45"
                                Margin="8"
                                Click="Cancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
